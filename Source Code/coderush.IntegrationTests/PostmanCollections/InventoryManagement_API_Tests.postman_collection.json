    "name": "Inventory Management — API Integration Tests",
    "description": "Comprehensive API integration tests for the ASP.NET Core Inventory & Order Management System.\n\nRun order: Use Postman Collection Runner or Newman CLI. The requests are ordered sequentially — authentication first, then reference data, master data, transactions, business-logic queries, and cleanup.\n\nPrerequisite: The application must be running at {{base_url}}.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01 — Authentication Setup",
      "item": [
        {
          "name": "01.1 Get Captcha Challenge",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response contains Token and PuzzleX', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property('Token');",
                  "    pm.expect(json).to.have.property('PuzzleX');",
                  "    pm.expect(json.PuzzleX).to.be.a('number');",
                  "    pm.environment.set('captcha_challenge_token', json.Token);",
                  "    pm.environment.set('captcha_puzzle_x', json.PuzzleX);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/api/Captcha/Challenge", "host": ["{{base_url}}"], "path": ["api","Captcha","Challenge"] }
          }
        },
        {
          "name": "01.2 Verify Captcha",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Captcha verification succeeded', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.Success).to.be.true;",
                  "    pm.expect(json).to.have.property('VerificationToken');",
                  "    pm.environment.set('captcha_verification_token', json.VerificationToken);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"Token\": \"{{captcha_challenge_token}}\",\n  \"UserX\": {{captcha_puzzle_x}},\n  \"SolveTimeMs\": 1000\n}"
            },
            "url": { "raw": "{{base_url}}/api/Captcha/Verify", "host": ["{{base_url}}"], "path": ["api","Captcha","Verify"] }
          }
        },
        {
          "name": "01.3 GET Login Page (extract anti-forgery token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Anti-forgery token extracted', function () {",
                  "    var html = pm.response.text();",
                  "    var match = html.match(/name=\"__RequestVerificationToken\"[^>]*value=\"([^\"]+)\"/);",
                  "    pm.expect(match).to.not.be.null;",
                  "    pm.environment.set('antiforgery_token', match[1]);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/Account/Login", "host": ["{{base_url}}"], "path": ["Account","Login"] }
          }
        },
        {
          "name": "01.4 POST Login (authenticate)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login redirects (302) or succeeds (200)', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 302]);",
                  "});",
                  "",
                  "pm.test('No invalid login error in body', function () {",
                  "    if (pm.response.code === 200) {",
                  "        pm.expect(pm.response.text()).to.not.include('Invalid login attempt');",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "Email", "value": "{{admin_email}}", "type": "text" },
                { "key": "Password", "value": "{{admin_password}}", "type": "text" },
                { "key": "RememberMe", "value": "true", "type": "text" },
                { "key": "CaptchaToken", "value": "{{captcha_verification_token}}", "type": "text" },
                { "key": "__RequestVerificationToken", "value": "{{antiforgery_token}}", "type": "text" }
              ]
            },
            "url": { "raw": "{{base_url}}/Account/Login", "host": ["{{base_url}}"], "path": ["Account","Login"] }
          }
        },
        {
          "name": "01.5 Verify Authenticated — GET api/Customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Authenticated — Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has Items and Count', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property('Items');",
                  "    pm.expect(json).to.have.property('Count');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/api/Customer", "host": ["{{base_url}}"], "path": ["api","Customer"] }
          }
        }
      ]
    },
