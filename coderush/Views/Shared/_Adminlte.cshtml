<!DOCTYPE html>
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject coderush.Data.ApplicationDbContext ApplicationDbContext
@{

    ApplicationUser appUser = await UserManager.GetUserAsync(User);

}
<html>
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">

    <title>@ViewData["Title"] - Inventory</title>
    <!-- Tell the browser to be responsive to screen width -->
    <meta content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" name="viewport">

    <!--AdminLTE-->
    <!-- Bootstrap 3.3.7 -->
    <link rel="stylesheet" href="~/adminlte/components/bootstrap/dist/css/bootstrap.min.css">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="~/adminlte/components/font-awesome/css/font-awesome.min.css">
    <!-- Ionicons -->
    <link rel="stylesheet" href="~/adminlte/components/Ionicons/css/ionicons.min.css">
    <!-- Pace style -->
    <link rel="stylesheet" href="~/adminlte/plugins/pace/pace.min.css">
    <!-- Theme style -->
    <link rel="stylesheet" href="~/adminlte/dist/css/AdminLTE.min.css">
    <!-- AdminLTE Skins. Choose a skin from the css/skins
         folder instead of downloading all of them to reduce the load. -->
    <link rel="stylesheet" href="~/adminlte/dist/css/skins/_all-skins.min.css">
    <!-- HTML5 Shim and Respond.js IE8 support of HTML5 elements and media queries -->
    <!-- WARNING: Respond.js doesn't work if you view the page via file:// -->
    <!--[if lt IE 9]>
    <script src="https://oss.maxcdn.com/html5shiv/3.7.3/html5shiv.min.js"></script>
    <script src="https://oss.maxcdn.com/respond/1.4.2/respond.min.js"></script>
    <![endif]-->
    <!-- Google Font -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Source+Sans+Pro:300,400,600,700,300italic,400italic,600italic">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Pacifico&display=swap">

    <!--Snycfusion-->
    <link href="~/content/ejthemes/bootstrap-theme/ej.web.all.min.css" rel="stylesheet" />
    <link href="~/content/default-responsive.css" rel="stylesheet" />
    <link href="~/content/ejthemes/responsive-css/ej.responsive.css" rel="stylesheet" />
    <link href="~/content/ejthemes/responsive-css/ejgrid.responsive.css" rel="stylesheet" />

    <style>
        .main-sidebar .sidebar.sidebar-scroll-host {
            height: calc(100vh - 50px);
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .main-sidebar .sidebar-menu-container {
            flex: 1 1 auto;
            min-height: 0;
            overflow-y: scroll;
            overflow-x: hidden;
            -webkit-overflow-scrolling: touch;
            scrollbar-width: auto;
            scrollbar-color: rgba(255, 255, 255, 0.45) rgba(0, 0, 0, 0.15);
            scrollbar-gutter: stable;
        }

        .main-sidebar .sidebar-menu-container::-webkit-scrollbar {
            width: 12px;
        }

        .main-sidebar .sidebar-menu-container::-webkit-scrollbar-track {
            background: rgba(0, 0, 0, 0.15);
        }

        .main-sidebar .sidebar-menu-container::-webkit-scrollbar-thumb {
            background-color: rgba(255, 255, 255, 0.45);
            border-radius: 999px;
            border: 2px solid rgba(0, 0, 0, 0.15);
        }
    </style>

    @RenderSection("Styles", required: false)

    <link rel="stylesheet" href="~/css/chatbot.css" asp-append-version="true" />

</head>
<body class="hold-transition skin-blue fixed sidebar-mini">
    <div class="wrapper">
        <partial name="_AdminlteMainHeader" model="appUser" />
        <!-- Left side column. contains the logo and sidebar -->
        <partial name="_AdminlteMainSidebar" model="appUser" />
        <!-- Content Wrapper. Contains page content -->
        @RenderBody()
        <!-- /.content-wrapper -->
        <partial name="_AdminlteFooter" />
    </div>
    <!-- ./wrapper -->
    <!--AdminLTE-->
    <!-- jQuery 3 -->
    <script src="~/adminlte/components/jquery/dist/jquery.min.js"></script>
    <!-- Bootstrap 3.3.7 -->
    <script src="~/adminlte/components/bootstrap/dist/js/bootstrap.min.js"></script>
    <!-- Slimscroll -->
    <script src="~/adminlte/components/jquery-slimscroll/jquery.slimscroll.min.js"></script>
    <!-- FastClick -->
    <script src="~/adminlte/components/fastclick/lib/fastclick.js"></script>
    <!-- AdminLTE App -->
    <script src="~/adminlte/dist/js/adminlte.min.js"></script>
    <script>
        window.paceOptions = {
            ajax: false,
            restartOnRequestAfter: false,
            restartOnPushState: false
        };
    </script>
    <!-- PACE -->
    <script src="~/adminlte/components/PACE/pace.min.js"></script>
    <script>
        window.addEventListener('load', function () {
            if (window.Pace) {
                window.Pace.stop();
            }
        });
    </script>

    <!--Syncfusion-->
    <script src="~/scripts/jsrender.min.js"></script>
    <script src="~/scripts/ej.web.all.min.js" type="text/javascript"></script>
    <script src="~/scripts/properties.js" type="text/javascript"></script>
    <script src="~/scripts/jquery.validate.min.js"></script>
    <script src="~/scripts/jquery.validate.unobtrusive.min.js"></script>

    @RenderSection("Scripts", required: false)

    <!-- AI Chatbot Panel -->
    <div id="chatbot-overlay"></div>
    <div id="chatbot-panel">
        <div class="chatbot-header">
            <div class="chatbot-header-left">
                <button id="chatbot-sidebar-toggle" class="chatbot-sidebar-btn" title="Conversations"><i class="fa fa-bars"></i></button>
                <h4><i class="fa fa-comments"></i> AI Assistant</h4>
            </div>
            <div class="chatbot-header-actions">
                <button id="chatbot-new-chat-btn" class="chatbot-new-btn" title="New conversation"><i class="fa fa-plus"></i></button>
                <button class="chatbot-clear-btn" onclick="confirmClearChat();" title="Delete conversation"><i class="fa fa-trash"></i></button>
                <button class="chatbot-close-btn" onclick="closeChatBot();">&times;</button>
            </div>
        </div>
        <div class="chatbot-body">
            <div id="chatbot-sidebar" class="chatbot-sidebar">
                <div class="chatbot-sidebar-header">
                    <span>Conversations</span>
                </div>
                <div class="chatbot-conversation-list" id="chatbot-conversation-list">
                    <div id="chatbot-pinned-section" class="chatbot-sidebar-section" style="display:none;">
                        <div class="chatbot-sidebar-section-label"><i class="fa fa-thumb-tack"></i> Pinned</div>
                        <div id="chatbot-pinned-list"></div>
                    </div>
                    <div id="chatbot-unpinned-section" class="chatbot-sidebar-section">
                        <div id="chatbot-unpinned-label" class="chatbot-sidebar-section-label" style="display:none;">Recent</div>
                        <div id="chatbot-unpinned-list"></div>
                    </div>
                </div>
                <div class="chatbot-sidebar-footer">
                    &reg;All Rights Reserved.
                </div>
            </div>
            <div id="chatbot-sidebar-overlay" class="chatbot-sidebar-overlay"></div>
            <div id="chatbot-confirm-dialog" class="chatbot-confirm-dialog" style="display:none;">
                <div class="chatbot-confirm-content">
                    <p>Are you sure you want to delete this conversation?</p>
                    <div class="chatbot-confirm-actions">
                        <button id="chatbot-confirm-yes" class="chatbot-confirm-yes">Yes</button>
                        <button id="chatbot-confirm-no" class="chatbot-confirm-no">No</button>
                    </div>
                </div>
            </div>
            <div class="chatbot-messages" id="chatbot-messages">
                <div class="chatbot-msg assistant">
                    <p>Hello! I'm your Inventory Management AI Assistant. I can help you with:</p>
                    <ul>
                        <li>Viewing products, customers, vendors, and orders</li>
                        <li>Creating new records</li>
                        <li>Searching and deleting data</li>
                        <li>Getting inventory summaries</li>
                        <li><strong>Analyzing uploaded files</strong> (.txt, .md, .docx, .xlsx)</li>
                    </ul>
                    <p>How can I help you today?</p>
                </div>
            </div>
        </div>
        <div id="chatbot-file-indicator" class="chatbot-file-indicator" style="display:none;">
            <div id="chatbot-file-list" class="chatbot-file-list"></div>
            <button id="chatbot-file-remove-all" type="button" title="Remove all files">&times; all</button>
        </div>
        <div class="chatbot-input-area">
            <input type="file" id="chatbot-file-input" accept=".txt,.md,.docx,.xlsx,.xls" multiple class="chatbot-sr-only" />
            <label id="chatbot-attach-btn" for="chatbot-file-input" class="needsclick" title="Attach a file"><i class="fa fa-paperclip needsclick"></i></label>
            <input type="text" id="chatbot-input" placeholder="Type your message..." autocomplete="off" />
            <button id="chatbot-send-btn"><i class="fa fa-paper-plane"></i></button>
            <button id="chatbot-stop-btn" style="display:none;" title="Stop response"><i class="fa fa-stop"></i></button>
        </div>
    </div>
    <script src="~/js/chatbot.js" asp-append-version="true"></script>

</body>
</html>